# ---------------------------------------------------------------------------
# URL pública del sitio (para las imágenes de previsualización al compartir).
# En local puedes dejarlo vacío; en producción pon tu dominio, p.ej.
# https://reel.tudominio.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# TMDB (The Movie Database) — https://www.themoviedb.org/settings/api
# Se usa SOLO en el servidor (route handlers). Nunca se expone al cliente.
# Usa el "API Read Access Token" (v4) que empieza por "eyJ...".
# ---------------------------------------------------------------------------
TMDB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Firebase — https://console.firebase.google.com/  (Project settings > General)
# Estas claves son públicas por diseño (van al cliente); la seguridad real
# se define en las reglas de Firestore (firestore.rules).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
